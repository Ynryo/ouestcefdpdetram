<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- Ligne de gauche (Train A / Tracé commun) -->
    <View
            android:id="@+id/vLineLeft"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:background="@drawable/timeline_bar_straight"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- Dot de gauche -->
    <View
            android:id="@+id/vStopDotLeft"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/timeline_dot_solid"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/vLineLeft"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- Ligne de droite (Train B) -->
    <View
            android:id="@+id/vLineRight"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:background="@drawable/timeline_bar_straight"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/vLineLeft" />

    <!-- Dot de droite -->
    <View
            android:id="@+id/vStopDotRight"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/timeline_dot_solid"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/vLineRight"
            app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
