<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minWidth="80dp"
        android:minHeight="100dp">

    <ImageView
            android:id="@+id/line_main"
            android:layout_width="20dp"
            android:layout_height="0dp"
            android:src="@drawable/timeline_bar_straight"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    <ImageView
            android:id="@+id/curve_top"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/timeline_branch_curve_top"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="@+id/line_main" />

    <View
            android:id="@+id/line_horizontal"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:background="@drawable/timeline_bar_straight"
            app:layout_constraintStart_toEndOf="@+id/curve_top"
            app:layout_constraintEnd_toStartOf="@+id/curve_bottom"
            app:layout_constraintBottom_toBottomOf="@+id/curve_top" />

    <ImageView
            android:id="@+id/curve_bottom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/timeline_branch_curve_bottom"
            app:layout_constraintTop_toTopOf="@+id/line_horizontal"
            app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
            android:id="@+id/line_secondary_down"
            android:layout_width="20dp"
            android:layout_height="0dp"
            android:src="@drawable/timeline_bar_straight"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/curve_bottom"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>